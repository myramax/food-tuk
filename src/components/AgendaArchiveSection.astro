---
import { getPageContent } from '../content';
import { getArchivedAgendaEvents, groupAgendaEventsByMonth } from '../lib/agenda';
import { getAgendaEvents } from '../lib/agenda-source';
import AgendaEventGroups from './AgendaEventGroups.astro';
import Section from './Section.astro';

const page = getPageContent('agenda');
const events = getArchivedAgendaEvents(await getAgendaEvents());
const groups = groupAgendaEventsByMonth(events);
const hasEvents = events.length > 0;
---

<Section bg="bg-brand-light" width="content">
  <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <p class="max-w-[620px] text-brand-subtle">{page.archiveIntro}</p>
    <a
      href="/agenda"
      class="inline-flex items-center gap-2 self-start text-sm font-semibold text-brand-primary transition-opacity duration-fast hover:opacity-70 md:self-auto"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" class="h-3 w-3" aria-hidden="true">
        <path fill="currentColor" d="M41.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.3 256 246.6 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z"/>
      </svg>
      {page.archiveBackLabel}
    </a>
  </div>

  {hasEvents ? (
    <AgendaEventGroups groups={groups} />
  ) : (
    <div class="reveal flex flex-col items-center py-16 text-center">
      <p class="max-w-sm text-brand-subtle">{page.archiveEmptyState}</p>
    </div>
  )}
</Section>
