---
import reviewsWidgetHtml from '../fragments/trustindex-google-widget.html?raw';
import { getPageContent } from '../content';
import Section from './Section.astro';

const { reviews } = getPageContent('home');
---

<Section bg="bg-brand-light" class="scroll-mt-40">
  <div id="reviews" class="space-y-6">
    <div class="flex items-end justify-between gap-6">
      <div class="reveal">
        <h2 class="font-display text-display font-semibold leading-[40px] text-brand-primary md:leading-[64px]">
          {reviews.heading}
        </h2>
        <p class="mt-2">{reviews.subhead}</p>
      </div>

      <a
        href={reviews.ctaUrl}
        target="_blank"
        rel="noreferrer"
        class="hidden items-center gap-2 text-base font-semibold text-brand-subtle underline min-[479px]:inline-flex"
      >
        <span>{reviews.ctaLabel}</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="h-5 w-5">
          <path fill="#9e9977" d="M471.6 21.7c-21.9-21.9-57.3-21.9-79.2 0L368 46.1 465.9 144 490.3 119.6c21.9-21.9 21.9-57.3 0-79.2L471.6 21.7zm-299.2 220c-6.1 6.1-10.8 13.6-13.5 21.9l-29.6 88.8c-2.9 8.6-.6 18.1 5.8 24.6s15.9 8.7 24.6 5.8l88.8-29.6c8.2-2.7 15.7-7.4 21.9-13.5L432 177.9 334.1 80 172.4 241.7zM96 64C43 64 0 107 0 160L0 416c0 53 43 96 96 96l256 0c53 0 96-43 96-96l0-96c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 96c0 17.7-14.3 32-32 32L96 448c-17.7 0-32-14.3-32-32l0-256c0-17.7 14.3-32 32-32l96 0c17.7 0 32-14.3 32-32s-14.3-32-32-32L96 64z"></path>
        </svg>
      </a>
    </div>

    <div class="reveal">
      <Fragment set:html={reviewsWidgetHtml} />
    </div>

    <a
      href={reviews.ctaUrl}
      target="_blank"
      rel="noreferrer"
      class="inline-flex items-center gap-2 text-sm font-semibold text-brand-subtle underline min-[479px]:hidden"
    >
      <span>{reviews.ctaLabel}</span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="h-4 w-4">
        <path fill="#9e9977" d="M471.6 21.7c-21.9-21.9-57.3-21.9-79.2 0L368 46.1 465.9 144 490.3 119.6c21.9-21.9 21.9-57.3 0-79.2L471.6 21.7zm-299.2 220c-6.1 6.1-10.8 13.6-13.5 21.9l-29.6 88.8c-2.9 8.6-.6 18.1 5.8 24.6s15.9 8.7 24.6 5.8l88.8-29.6c8.2-2.7 15.7-7.4 21.9-13.5L432 177.9 334.1 80 172.4 241.7zM96 64C43 64 0 107 0 160L0 416c0 53 43 96 96 96l256 0c53 0 96-43 96-96l0-96c0-17.7-14.3-32-32-32s-32 14.3-32 32l0 96c0 17.7-14.3 32-32 32L96 448c-17.7 0-32-14.3-32-32l0-256c0-17.7 14.3-32 32-32l96 0c17.7 0 32-14.3 32-32s-14.3-32-32-32L96 64z"></path>
      </svg>
    </a>
  </div>

  <script is:inline async src="https://cdn.trustindex.io/loader.js"></script>
</Section>
