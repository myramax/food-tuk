---
import { getPageContent } from '../content';

const { heading, subhead } = getPageContent('agenda');
---

<section class="bg-brand-light px-4">
  <div class="mx-auto w-full">
    <div class="flex min-h-[38vh] flex-col items-center justify-center pt-[140px] pb-12 text-center md:pt-[160px]">
      <p class="mb-4 font-body text-xs font-semibold uppercase tracking-[0.22em] text-brand-primary">
        Waar vind je ons
      </p>
      <h1 class="reveal font-display text-display font-bold leading-tight text-brand-dark">
        {heading}
      </h1>
      <div class="mt-5 h-[2px] w-12 rounded-full bg-brand-primary"></div>
      <p class="mt-5 max-w-[480px] text-brand-subtle">
        {subhead}
      </p>
    </div>
  </div>
</section>
