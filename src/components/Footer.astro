---

<footer class="bg-brand-dark">
  <section class="px-4 py-[60px]">
    <div class="mx-auto max-w-[1280px]">
      <div class="grid items-start justify-items-center gap-8 max-[478px]:justify-items-start max-[478px]:px-4 sm:grid-cols-2 lg:grid-cols-3">
        <div>
          <h6 class="mb-[6px] font-display text-base font-semibold text-text">{footer.socialsHeading}</h6>
          <ul class="space-y-2">
            {footer.socials.map((item) => {
              const icon = icons[item.icon];
              return (
                <li>
                  <a href={item.url} class="flex items-center text-base text-brand-subtle transition-colors duration-fast hover:text-brand-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox={icon.viewBox} class="h-5 w-5 shrink-0">
                      <path fill="#9e9977" d={icon.path}></path>
                    </svg>
                    <span class="ml-2">{item.label}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>

        <div>
          <h6 class="mb-[6px] font-display text-base font-semibold text-text">{footer.contactHeading}</h6>
          <ul class="space-y-2">
            {footer.contacts.map((item) => {
              const icon = icons[item.icon];
              return (
                <li>
                  <a href={item.href} class="flex items-center text-base text-brand-subtle transition-colors duration-fast hover:text-brand-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox={icon.viewBox} class="h-5 w-5 shrink-0">
                      <path fill="#9e9977" d={icon.path}></path>
                    </svg>
                    <span class="ml-[6px]">{item.label}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>

        <div class="max-[478px]:text-left">
          <h6 class="mb-[6px] font-display text-base font-semibold text-text">{footer.businessHeading}</h6>
          <div class="space-y-1 text-base text-brand-subtle">
            {footer.businessLines.map((line) => <div>{line}</div>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="flex items-center justify-center px-4 pb-4">
    <a href={footer.credit.url} class="text-center text-xs font-normal text-brand-subtle transition-colors duration-fast hover:text-brand-primary">
      {footer.credit.label}
    </a>
  </div>
</footer>
