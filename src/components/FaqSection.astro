---
import { getPageContent } from '../content';
import Section from './Section.astro';

const { faq } = getPageContent('home');
---

<Section
  bg="bg-brand-accent border-y border-dotted border-brand-primary scroll-mt-40"
  class="scroll-mt-40"
>
  <div id="faq" class="flex flex-col justify-between gap-10 lg:flex-row lg:gap-20">
    <div class="reveal max-w-[500px]">
      <h2 class="font-display text-display font-semibold leading-[40px] text-brand-primary md:leading-[64px]">
        {faq.heading}
      </h2>
      <div class="mt-4 foodtuk-prose" set:html={faq.subtitleHtml}></div>
    </div>

    <div class="reveal w-full max-w-[700px]">
      <div class="space-y-4" data-faq-list>
        {faq.items.map((item) => (
          <details class="group rounded-[16px] border border-brand-soft bg-[#fff3bf] transition-colors duration-fast hover:bg-[#fff0b0] open:bg-brand-panel-open" data-faq-item>
            <summary class="flex cursor-pointer items-center gap-3 px-4 py-[15px]" data-faq-summary>
              <h3 class="flex-1 font-display text-[20px] font-bold leading-[30px] text-brand-primary">
                {item.question}
              </h3>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="h-4 w-4 text-brand-primary transition-transform duration-fast group-open:rotate-90">
                <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="48" d="M184 112l144 144-144 144"></path>
              </svg>
            </summary>
            <div class="foodtuk-prose px-4 pb-[15px] text-[16px] leading-6 text-brand-subtle" set:html={item.answerHtml}></div>
          </details>
        ))}
      </div>
    </div>
  </div>
</Section>

<script>
  const faqList = document.querySelector('[data-faq-list]');
  const hoverQuery = window.matchMedia('(hover: hover) and (pointer: fine)');

  if (faqList instanceof HTMLElement) {
    const items = Array.from(faqList.querySelectorAll('[data-faq-item]')).filter(
      (item): item is HTMLDetailsElement => item instanceof HTMLDetailsElement,
    );

    const closeOthers = (current: HTMLDetailsElement) => {
      items.forEach((item) => {
        if (item !== current) item.open = false;
      });
    };

    items.forEach((item) => {
      const summary = item.querySelector('[data-faq-summary]');

      item.addEventListener('mouseenter', () => {
        if (!hoverQuery.matches) return;
        closeOthers(item);
        item.open = true;
      });

      item.addEventListener('mouseleave', () => {
        if (!hoverQuery.matches) return;
        item.open = false;
      });

      item.addEventListener('toggle', () => {
        if (!hoverQuery.matches && item.open) closeOthers(item);
      });

      summary?.addEventListener('click', (event) => {
        if (hoverQuery.matches) event.preventDefault();
      });

      item.addEventListener('focusin', () => {
        if (!hoverQuery.matches) return;
        closeOthers(item);
        item.open = true;
      });

      item.addEventListener('focusout', (event) => {
        if (!hoverQuery.matches) return;
        const nextTarget = event.relatedTarget;
        if (nextTarget instanceof Node && item.contains(nextTarget)) return;
        item.open = false;
      });
    });
  }
</script>
