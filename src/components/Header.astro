---
import { getCommonContent } from '../content';

const { header } = getCommonContent();
const navItems = header.nav.filter((item) => !item.button);
const ctaItem = header.nav.find((item) => item.button);
---

<header class="fixed inset-x-0 top-0 z-[2000] mt-[30px] px-4 max-md:mt-2 md:px-[30px]">
  <div class="mx-auto max-w-[1280px]">
    <nav
      data-site-nav
      class="relative flex items-center justify-between rounded-[30px] border-[4px] border-brand-primary bg-[rgba(255,250,221,0.89)] px-5 py-2 max-md:border-2 md:px-10 md:py-[10px]"
      aria-label="Menu"
    >
      <!-- Logo desktop -->
      <a href="/" class="hidden w-[60px] shrink-0 md:block">
        <img src="/images/FoodTuk-logo.webp" alt={header.logoAlt} class="w-full" loading="eager" decoding="async" />
      </a>

      <!-- Desktop nav links -->
      <div class="hidden md:flex md:flex-1 md:items-center md:justify-center md:gap-10 lg:gap-20">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="text-base text-brand-primary transition-opacity duration-fast hover:opacity-80"
            data-nav-link
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- Desktop CTA button -->
      {ctaItem && (
        <a
          href={ctaItem.href}
          class="hidden shrink-0 rounded-md bg-brand-primary px-4 py-2 text-sm font-semibold text-white transition-opacity duration-fast hover:opacity-90 md:inline-flex md:items-center"
          data-nav-link
        >
          {ctaItem.label}
        </a>
      )}

      <!-- Logo mobile -->
      <a href="/" class="w-10 shrink-0 md:hidden">
        <img src="/images/FoodTuk-logo.webp" alt={header.logoAlt} class="w-full" loading="eager" decoding="async" />
      </a>

      <!-- Hamburger toggle -->
      <button
        type="button"
        data-mobile-toggle
        aria-expanded="false"
        aria-label={header.menuOpen}
        class="relative z-50 ml-auto flex h-6 w-6 shrink-0 flex-col items-center justify-between py-0.5 md:hidden"
      >
        <span class="hamburger-line block h-0.5 w-full rounded-full bg-brand-primary transition-all duration-300"></span>
        <span class="hamburger-line block h-0.5 w-full rounded-full bg-brand-primary transition-all duration-300"></span>
        <span class="hamburger-line block h-0.5 w-full rounded-full bg-brand-primary transition-all duration-300"></span>
      </button>

      <!-- Mobile dropdown panel -->
      <div
        data-mobile-panel
        class="invisible absolute left-[-2px] right-[-2px] top-[calc(100%+10px)] rounded-[20px] border border-brand-soft bg-brand-panel px-6 pb-7 pt-6 opacity-0 shadow-lg transition-all duration-300 md:hidden"
      >
        <ul class="flex flex-col items-center gap-5">
          {navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="font-display text-xl font-semibold text-brand-primary transition-opacity duration-fast hover:opacity-70"
                data-nav-link
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>

        {ctaItem && (
          <div class="mt-6 flex justify-center">
            <a
              href={ctaItem.href}
              class="inline-flex items-center justify-center rounded-md bg-brand-primary px-6 py-3 text-base font-semibold text-white transition-opacity duration-fast hover:opacity-90"
              data-nav-link
            >
              {ctaItem.label}
            </a>
          </div>
        )}
      </div>
    </nav>
  </div>
</header>

<script>
  const nav = document.querySelector('[data-site-nav]');
  const button = nav?.querySelector('[data-mobile-toggle]') as HTMLButtonElement | null;
  const panel = nav?.querySelector('[data-mobile-panel]') as HTMLElement | null;
  const lines = button?.querySelectorAll('.hamburger-line') ?? [];
  const links = nav?.querySelectorAll('[data-nav-link]') ?? [];

  if (button && panel) {
    const setOpen = (open: boolean) => {
      panel.classList.toggle('invisible', !open);
      panel.classList.toggle('opacity-0', !open);
      panel.classList.toggle('opacity-100', open);
      button.setAttribute('aria-expanded', String(open));
      button.setAttribute('aria-label', open ? 'Sluit menu' : 'Open menu');
      document.body.classList.toggle('overflow-hidden', open);

      // Hamburger → X
      const [l1, l2, l3] = Array.from(lines) as HTMLElement[];
      if (open) {
        l1?.style.setProperty('transform', 'translateY(9px) rotate(45deg)');
        l2?.style.setProperty('opacity', '0');
        l3?.style.setProperty('transform', 'translateY(-9px) rotate(-45deg)');
      } else {
        l1?.style.removeProperty('transform');
        l2?.style.removeProperty('opacity');
        l3?.style.removeProperty('transform');
      }
    };

    button.addEventListener('click', () => setOpen(button.getAttribute('aria-expanded') !== 'true'));

    links.forEach((link) => link.addEventListener('click', () => setOpen(false)));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) setOpen(false);
    });
  }
</script>
