---
import { getPageContent } from '../content';
import Section from './Section.astro';

const page = getPageContent('agenda');
const hasEvents = page.events.length > 0;
---

<Section bg="bg-brand-light" width="content">
  {hasEvents ? (
    <ul class="space-y-3" role="list">
      {page.events.map((event, i) => (
        <li
          class="reveal group flex items-stretch overflow-hidden rounded-lg border border-brand-soft border-l-[3px] border-l-brand-primary bg-brand-panel transition-shadow duration-base hover:shadow-md"
          style={`transition-delay:${i * 70}ms`}
        >
          <div class="flex flex-1 flex-col gap-1.5 px-6 py-5 md:flex-row md:items-center md:gap-0 md:px-8 md:py-6">
            <!-- Datum + naam als eenheid -->
            <div class="flex-1">
              <p class="font-body text-xs font-semibold uppercase tracking-[0.16em] text-brand-primary">
                {event.dayName} · {event.day} {event.month}
              </p>
              <h2 class="mt-1 font-display text-heading font-bold leading-snug text-brand-primary">
                {event.name}
              </h2>
              <div class="mt-2 flex flex-wrap gap-x-4 gap-y-0.5">
                <span class="flex items-center gap-1.5 text-sm text-brand-subtle">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512" class="h-3 w-3 shrink-0" aria-hidden="true">
                    <path fill="currentColor" d="M215.7 499.2C267 435 384 279.4 384 192C384 86 298 0 192 0S0 86 0 192c0 87.4 117 243 168.3 307.2c12.3 15.3 35.1 15.3 47.4 0zM192 128a64 64 0 1 1 0 128 64 64 0 1 1 0-128z"/>
                  </svg>
                  {event.location}
                </span>
                <span class="flex items-center gap-1.5 text-sm text-brand-subtle">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" class="h-3 w-3 shrink-0" aria-hidden="true">
                    <path fill="currentColor" d="M256 0a256 256 0 1 1 0 512A256 256 0 1 1 256 0zM232 120l0 136c0 8 4 15.5 10.7 20l96 64c11 7.4 25.9 4.5 33.3-6.5s4.5-25.9-6.5-33.3L280 243.2 280 120c0-13.3-10.7-24-24-24s-24 10.7-24 24z"/>
                  </svg>
                  {event.time}
                </span>
              </div>
            </div>

            {event.url && (
              <a
                href={event.url}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex shrink-0 items-center gap-1.5 self-start text-sm font-semibold text-brand-primary transition-opacity duration-fast hover:opacity-70 md:mt-0 md:self-center md:pl-8"
              >
                {event.urlLabel}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" class="h-3 w-3" aria-hidden="true">
                  <path fill="currentColor" d="M278.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-160 160c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L210.7 256 73.4 118.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l160 160z"/>
                </svg>
              </a>
            )}
          </div>
        </li>
      ))}
    </ul>
  ) : (
    <div class="reveal flex flex-col items-center py-20 text-center">
      <p class="max-w-sm text-brand-subtle">{page.emptyState}</p>
      <a
        href="/#offerte-contact"
        class="mt-6 inline-flex items-center justify-center rounded-md bg-brand-primary px-6 py-4 text-base font-semibold leading-4 text-white transition-transform duration-fast hover:-translate-y-0.5"
      >
        {page.emptyCtaLabel}
      </a>
    </div>
  )}
</Section>

<section class="bg-brand-dark py-section">
  <div class="reveal mx-auto max-w-5xl px-6 text-center lg:px-12">
    <h2 class="font-display text-heading font-bold text-text">
      {page.bottomCta.heading}
    </h2>
    <p class="mt-3 text-brand-subtle">{page.bottomCta.body}</p>
    <a
      href={page.bottomCta.href}
      class="mt-6 inline-flex items-center justify-center rounded-md bg-brand-primary px-6 py-4 text-base font-semibold leading-4 text-brand-dark transition-transform duration-fast hover:-translate-y-0.5"
    >
      {page.bottomCta.label}
    </a>
  </div>
</section>
