---
import { getPageContent } from '../content';
import { getArchivedAgendaEvents, getUpcomingAgendaEvents, groupAgendaEventsByMonth } from '../lib/agenda';
import { getAgendaEvents } from '../lib/agenda-source';
import AgendaEventGroups from './AgendaEventGroups.astro';
import Section from './Section.astro';

const page = getPageContent('agenda');
const PAGE_SIZE = 5;
const agendaEvents = await getAgendaEvents();
const eventsWithIdx = getUpcomingAgendaEvents(agendaEvents);
const archivedEvents = getArchivedAgendaEvents(agendaEvents);
const hasEvents = eventsWithIdx.length > 0;
const hasArchive = archivedEvents.length > 0;
const groups = groupAgendaEventsByMonth(eventsWithIdx);
const totalPages = Math.ceil(eventsWithIdx.length / PAGE_SIZE);
const pageNumbers = Array.from({ length: totalPages }, (_, i) => i + 1);
---

<Section bg="bg-brand-light" width="content">
  {hasEvents ? (
    <div data-agenda-root data-page-size={PAGE_SIZE} data-total-pages={totalPages}>
      <AgendaEventGroups groups={groups} paginated />

      {totalPages > 1 && (
        <div data-pagination class="mt-10 flex items-center justify-center gap-2">
          <button
            data-prev
            class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-brand-soft text-brand-primary transition-colors duration-fast hover:border-brand-primary disabled:pointer-events-none disabled:cursor-default disabled:opacity-30"
            aria-label="Vorige pagina"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" class="h-3 w-3" aria-hidden="true">
              <path fill="currentColor" d="M41.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.3 256 246.6 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z"/>
            </svg>
          </button>

          {pageNumbers.map((n) => (
            <button
              data-page={n}
              class="flex h-9 min-w-[2.25rem] cursor-pointer items-center justify-center rounded-full border px-3 text-sm font-semibold transition-colors duration-fast"
              aria-label={`Pagina ${n}`}
            >
              {n}
            </button>
          ))}

          <button
            data-next
            class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-brand-soft text-brand-primary transition-colors duration-fast hover:border-brand-primary disabled:pointer-events-none disabled:cursor-default disabled:opacity-30"
            aria-label="Volgende pagina"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" class="h-3 w-3" aria-hidden="true">
              <path fill="currentColor" d="M278.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-160 160c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L210.7 256 73.4 118.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l160 160z"/>
            </svg>
          </button>
        </div>
      )}

      {hasArchive && (
        <div class="mt-8 flex justify-center">
          <a
            href="/agenda/archief"
            class="inline-flex items-center gap-2 text-sm font-semibold text-brand-primary transition-opacity duration-fast hover:opacity-70"
          >
            Bekijk eerdere events
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" class="h-3 w-3" aria-hidden="true">
              <path fill="currentColor" d="M278.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-160 160c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L210.7 256 73.4 118.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l160 160z"/>
            </svg>
          </a>
        </div>
      )}
    </div>
  ) : (
    <div class="reveal flex flex-col items-center py-20 text-center">
      <p class="max-w-sm text-brand-subtle">{page.emptyState}</p>
      <a
        href={page.emptyCtaHref}
        class="mt-6 inline-flex items-center justify-center rounded-md bg-brand-primary px-6 py-4 text-base font-semibold leading-4 text-white transition-transform duration-fast hover:-translate-y-0.5"
      >
        {page.emptyCtaLabel}
      </a>
    </div>
  )}
</Section>

<Section bg="bg-brand-accent border-y border-dotted border-brand-primary" width="content">
  <div class="reveal flex flex-col items-center text-center">
    <h2 class="font-display text-display font-semibold leading-tight text-brand-primary md:leading-[64px]">
      {page.bottomCta.heading}
    </h2>
    <p class="mt-4 max-w-[520px]">{page.bottomCta.body}</p>
    <a
      href={page.bottomCta.href}
      class="mt-6 inline-flex items-center justify-center rounded-md bg-brand-primary px-6 py-4 text-base font-semibold leading-4 text-white transition-transform duration-fast hover:-translate-y-0.5"
    >
      {page.bottomCta.label}
    </a>
  </div>
</Section>

{hasEvents && totalPages > 1 && (
  <script>
    const root = document.querySelector('[data-agenda-root]');

    if (root instanceof HTMLElement) {
      const pageSize = Number(root.dataset.pageSize ?? 5);
      const totalPages = Number(root.dataset.totalPages ?? 1);
      const prevBtn = root.querySelector('[data-prev]');
      const nextBtn = root.querySelector('[data-next]');
      const pageBtns = root.querySelectorAll('[data-page]');
      let currentPage = 1;

      const setPageBtnStyle = (btn: HTMLElement, active: boolean) => {
        if (active) {
          btn.classList.add('bg-brand-primary', 'text-brand-dark', 'border-brand-primary');
          btn.classList.remove('border-brand-soft', 'text-brand-subtle', 'hover:border-brand-primary');
        } else {
          btn.classList.remove('bg-brand-primary', 'text-brand-dark', 'border-brand-primary');
          btn.classList.add('border-brand-soft', 'text-brand-subtle', 'hover:border-brand-primary');
        }
      };

      const showPage = (page: number) => {
        const start = (page - 1) * pageSize;
        const end = start + pageSize - 1;

        root.querySelectorAll('[data-event-idx]').forEach((el) => {
          if (!(el instanceof HTMLElement)) return;
          const idx = Number(el.dataset.eventIdx);
          el.style.display = idx >= start && idx <= end ? '' : 'none';
        });

        root.querySelectorAll('[data-month-group]').forEach((el) => {
          if (!(el instanceof HTMLElement)) return;
          const groupStart = Number(el.dataset.start);
          const groupEnd = Number(el.dataset.end);
          el.style.display = groupEnd >= start && groupStart <= end ? '' : 'none';
        });

        pageBtns.forEach((btn) => {
          if (!(btn instanceof HTMLElement)) return;
          setPageBtnStyle(btn, Number(btn.dataset.page) === page);
        });

        if (prevBtn instanceof HTMLButtonElement) prevBtn.disabled = page <= 1;
        if (nextBtn instanceof HTMLButtonElement) nextBtn.disabled = page >= totalPages;

        currentPage = page;
      };

      pageBtns.forEach((btn) => {
        if (!(btn instanceof HTMLElement)) return;
        setPageBtnStyle(btn, false);
      });
      showPage(1);

      if (prevBtn instanceof HTMLButtonElement) {
        prevBtn.addEventListener('click', () => {
          if (currentPage > 1) showPage(currentPage - 1);
        });
      }

      if (nextBtn instanceof HTMLButtonElement) {
        nextBtn.addEventListener('click', () => {
          if (currentPage < totalPages) showPage(currentPage + 1);
        });
      }

      pageBtns.forEach((btn) => {
        if (!(btn instanceof HTMLElement)) return;
        btn.addEventListener('click', () => showPage(Number(btn.dataset.page)));
      });
    }
  </script>
)}
