---
import Base from '../layouts/Base.astro';
import { getPageContent } from '../content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AgendaHeroSection from '../components/AgendaHeroSection.astro';
import AgendaEventsSection from '../components/AgendaEventsSection.astro';
import PhotoMarquee from '../components/PhotoMarquee.astro';

const page = getPageContent('agenda');
---

<Base title={page.meta.title} description={page.meta.description}>
  <Header />

  <main id="main-content">
    <AgendaHeroSection />
    <AgendaEventsSection />
    <PhotoMarquee />
  </main>

  <Footer />
</Base>
